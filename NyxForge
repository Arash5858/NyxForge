import os
import shutil
from pathlib import Path

class NyxForge:
    def __init__(self, source_dir):
        self.source_dir = Path(source_dir)

    def organize(self):
        for file in self.source_dir.iterdir():
            if file.is_file():
                extension = file.suffix[1:] or "unknown"
                target_dir = self.source_dir / extension.upper()

                target_dir.mkdir(exist_ok=True)

                destination = target_dir / file.name
                shutil.move(str(file), str(destination))
                print(f"Moved: {file.name} → {target_dir.name}/")

if __name__ == "__main__":
    path = input("Enter directory path: ")
    organizer = NyxForge(path)
    organizer.organize()
